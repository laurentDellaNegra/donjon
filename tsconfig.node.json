{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/cli/**/*.ts",
    "src/init/**/*.ts",
    "src/runtime/**/*.ts",
    "src/server/**/*.ts",
    "src/wrapper/**/*.ts",
    "src/types/**/*.d.ts",
    "src/index.ts"
  ]
}
